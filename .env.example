# ============ Frontend (Next.js) ============
# Base URL of the API (used in browser)
NEXT_PUBLIC_API_URL=http://localhost:8000
# Server-side API URL (production: set to internal backend, e.g. http://127.0.0.1:8010)
# BACKEND_URL=http://127.0.0.1:8010

# NextAuth.js
NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32
NEXTAUTH_URL=http://localhost:3000

# Google OAuth (optional for MVP)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ============ Backend (FastAPI) ============
# PostgreSQL (async driver)
DATABASE_URL=postgresql+asyncpg://admin@localhost:5432/wishlist

# JWT & session
SECRET_KEY=generate-with-openssl-rand-base64-32

# CORS (comma-separated origins; for production add Vercel URL)
CORS_ORIGINS=http://localhost:3000
# CORS_ORIGINS=https://your-app.vercel.app

# 2FA for password/email change: send code to user's email. Set SMTP_* to enable.
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# EMAIL_FROM=noreply@yourdomain.com
# For local dev without SMTP: set to 1 to log code to console and return it in API response
# EMAIL_ECHO_CODE=0
